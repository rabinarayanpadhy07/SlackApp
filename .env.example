PORT=3000
NODE_ENV=production

# Database
DEV_DB_URL=mongodb://127.0.0.1:27017/slackapp-dev
PROD_DB_URL=mongodb://127.0.0.1:27017/slackapp-prod

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY=1d
PASSWORD_RESET_TOKEN_EXPIRY_MS=3600000
ENABLE_EMAIL_VERIFICATION=true

# URLs
APP_LINK=https://api.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# Email
MAIL_ID=your-email@example.com
MAIL_PASSWORD=your-app-password

# Redis / queues
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# AWS uploads
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET_NAME=your-bucket

# Payments
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
CURRENCY=INR
RECEIPT_SECRET=receipt_secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/v1/users/auth/google/callback

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Admin / monitoring
SUPER_ADMIN_EMAILS=admin@yourdomain.com
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Security / rate limit
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
REQUEST_SIZE_LIMIT=1mb
